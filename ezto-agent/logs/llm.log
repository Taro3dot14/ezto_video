// ─── Helper: typewriter text line ─────────────────────────────────
function TypeLine({
	text,
	delay,
	className,
	mono,
}: {
	text: string;
	delay: number;
	className?: string;
	mono?: boolean;
}) {
	return (
		<div
			className={className ?? ''}
			style={{
				fontFamily: mono ? 'var(--font-mono)' : 'var(--font-display-cn)',
				fontSize: mono ? '20px' : '28px',
				color: 'var(--text)',
				whiteSpace: 'pre-wrap',
				overflow: 'hidden',
				animation: `c1-type-in 0.5s ease-out ${delay}s both`,
				lineHeight: 1.6,
			}}
		>
			{text}
			<span
				style={{
					display: 'inline-block',
					width: '2px',
					height: '1.2em',
					background: 'var(--accent)',
					marginLeft: '4px',
					verticalAlign: 'text-bottom',
					animation: 'c1-blink 0.7s step-end infinite',
				}}
			/>
		</div>
	);
}

// ─── Helper: hero text block ──────────────────────────────────────
function HeroText({
	lines,
	className,
	size = 80,
}: {
	lines: { text: string; accent?: boolean; mono?: boolean; small?: boolean }[];
	className?: string;
	size?: number;
}) {
	return (
		<div
			className={className ?? ''}
			style={{
				display: 'flex',
				flexDirection: 'column',
				alignItems: 'center',
				gap: '12px',
				textAlign: 'center',
			}}
		>
			{lines.map((l, i) => (
				<span
					key={i}
					style={{
						fontFamily: l.mono ? 'var(--font-mono)' : 'var(--font-display-cn)',
						fontSize: l.small ? size * 0.45 : size,
						fontWeight: l.accent ? 700 : 400,
						color: l.accent ? 'var(--accent)' : 'var(--text)',
						lineHeight: 1.2,
						letterSpacing: l.accent ? '2px' : '0',
						textShadow: l.accent
							? '0 0 60px var(--accent-glow), 0 0 120px var(--accent-glow)'
							: 'none',
						animation: `c1-hero-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.2}s both`,
					}}
				>
					{l.text}
				</span>
			))}
		</div>
	);
}

